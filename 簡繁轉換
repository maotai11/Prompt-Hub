// ========== Conversion Engine ==========
function convertS2T(text) {
  if (!text) return '';
  
  let result = '';
  let i = 0;
  const len = text.length;
  
  while (i < len) {
    let matched = false;
    // Try matching phrases from longest to shortest (max 6 chars)
    for (let pLen = Math.min(6, len - i); pLen >= 2; pLen--) {
      const substr = text.substring(i, i + pLen);
      if (S2T_PHRASES[substr]) {
        result += S2T_PHRASES[substr];
        i += pLen;
        matched = true;
        break;
      }
    }
    if (!matched) {
      const ch = text[i];
      result += S2T_DICT[ch] || ch;
      i++;
    }
  }
  
  return result;
}

// ========== Count converted characters ==========
function countConverted(original, converted) {
  let count = 0;
  const len = Math.min(original.length, converted.length);
  // This is approximate since phrase conversions change length
  for (let i = 0; i < len; i++) {
    if (original[i] !== converted[i]) count++;
  }
  // Also count extra chars from length difference
  count += Math.abs(original.length - converted.length);
  return count;
}

// ========== UI Logic ==========
const inputEl = document.getElementById('inputText');
const outputEl = document.getElementById('outputArea');
const inputCountEl = document.getElementById('inputCount');
const outputCountEl = document.getElementById('outputCount');
const autoToggle = document.getElementById('autoToggle');
const statsArea = document.getElementById('statsArea');
const statConverted = document.getElementById('statConverted');
const statTime = document.getElementById('statTime');

let debounceTimer = null;

function updateInputCount() {
  const len = inputEl.value.length;
  inputCountEl.textContent = len.toLocaleString() + ' 字';
}

function doConvert() {
  const text = inputEl.value;
  if (!text.trim()) {
    outputEl.textContent = '請先貼上文字';
    outputEl.className = 'output-area empty';
    outputCountEl.textContent = '0 字';
    statsArea.style.display = 'none';
    showToast('⚠️ 請先貼上文字');
    return;
  }
  
  const start = performance.now();
  const result = convertS2T(text);
  const elapsed = (performance.now() - start).toFixed(1);
  
  outputEl.textContent = result;
  outputEl.className = 'output-area';
  outputCountEl.textContent = result.length.toLocaleString() + ' 字';
  
  const changedCount = countConverted(text, result);
  statsArea.style.display = 'flex';
  statConverted.textContent = '轉換 ' + changedCount + ' 處';
  statTime.textContent = '耗時 ' + elapsed + ' ms';
  
  showToast('✅ 轉換完成');
}

function doCopy() {
  const text = outputEl.textContent;
  if (!text || outputEl.classList.contains('empty')) {
    showToast('⚠️ 沒有可複製的結果');
    return;
  }
  
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(text).then(() => {
      showToast('📋 已複製到剪貼簿');
    }).catch(() => {
      fallbackCopy(text);
    });
  } else {
    fallbackCopy(text);
  }
}

function fallbackCopy(text) {
  const ta = document.createElement('textarea');
  ta.value = text;
  ta.style.position = 'fixed';
  ta.style.left = '-9999px';
  document.body.appendChild(ta);
  ta.select();
  try {
    document.execCommand('copy');
    showToast('📋 已複製到剪貼簿');
  } catch (e) {
    showToast('❌ 複製失敗，請手動選取');
  }
  document.body.removeChild(ta);
}

function doClear() {
  inputEl.value = '';
  outputEl.textContent = '轉換結果將顯示在這裡';
  outputEl.className = 'output-area empty';
  inputCountEl.textContent = '0 字';
  outputCountEl.textContent = '0 字';
  statsArea.style.display = 'none';
  inputEl.focus();
  showToast('🗑️ 已清空');
}

function onAutoToggle() {
  if (autoToggle.checked && inputEl.value.trim()) {
    doConvert();
  }
}

inputEl.addEventListener('input', () => {
  updateInputCount();
  if (autoToggle.checked) {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(doConvert, 300);
  }
});

let toastTimer = null;
function showToast(msg) {
  const toast = document.getElementById('toast');
  toast.textContent = msg;
  toast.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => {
    toast.classList.remove('show');
  }, 2000);
}

// Keyboard shortcut: Ctrl+Enter to convert
document.addEventListener('keydown', (e) => {
  if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
    e.preventDefault();
    doConvert();
  }
});
